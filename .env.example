# Database (PostgreSQL + TimescaleDB)
DATABASE_URL=postgresql://signals:signals@localhost:5433/signals

# Kafka / Redpanda
KAFKA_BOOTSTRAP_SERVERS=localhost:19092

# Polygon.io
POLYGON_API_KEY=

# Perigon News (https://www.perigon.io/)
PERIGON_API_KEY=
# Optional: default https://api.perigon.io/v1/articles/all
# PERIGON_ARTICLES_URL=
# PERIGON_COUNTRY=us
# PERIGON_LANGUAGE=en
# PERIGON_CATEGORY=Business
# PERIGON_PAGE_SIZE=100
# PERIGON_MAX_PAGES=10

# Liquidity filter
MIN_MARKET_CAP_USD=300000000
MIN_ADV_SHARES=500000
ADV_LOOKBACK_DAYS=20

# API (signal-api)
SIGNAL_API_KEYS=dev-key-change-me
API_HOST=0.0.0.0
API_PORT=8080
# Railway injects PORT; the app accepts PORT or API_PORT (see signal_common.config Settings.api_port)
# Public browser UI: unauthenticated GET /public/v1/signals and /public/v1/sector-sentiment (same data as keyed /v1/*)
ENABLE_PUBLIC_SIGNAL_UI=false
# Optional: comma-separated origins for split deploy (e.g. https://yoursite.netlify.app) — enables CORS on GET
# CORS_ALLOWED_ORIGINS=

# NLP
FINBERT_MODEL=yiyanghkust/finbert-tone
NLP_BATCH_SIZE=8

# Regime / benchmarks
BENCHMARK_SYMBOL=SPY
# Comma-separated extra ETFs to ingest (beyond built-in sector ETF list + SPY/QQQ)
EXTRA_BENCHMARK_ETFS=
VIX_SYMBOL=I:VIX
REGIME_SPY_BELOW_MA_DAMPEN=0.5
REGIME_VIX_THRESHOLD=25

# Signal thresholds (conviction in [-1, 1])
SIGNAL_BUY_THRESHOLD=0.65
SIGNAL_SHORT_THRESHOLD=-0.65
SIGNAL_EXIT_THRESHOLD=-0.40
WEIGHT_TECHNICAL=0.45
WEIGHT_SENTIMENT=0.35
WEIGHT_FUNDAMENTAL=0.20
SIGNALS_ONLY_ON_TRADING_DAYS=false
WATCHLIST_ABS_CONVICTION_MIN=0.35
FUNDAMENTALS_INGEST_SYMBOL_LIMIT=80
PERSIST_SIGNAL_RUNS=true
